# ── Core ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-use-openssl-rand-hex-32
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
DEBUG=true
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://autollm:autollm@localhost:5432/autollm

# ── Redis ────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Google OAuth (optional — get from console.cloud.google.com) ──────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# ── Stripe (optional) ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_MAX=

# ── Email (optional — SendGrid) ──────────────────────────────────────────
SENDGRID_API_KEY=
EMAIL_FROM=noreply@autollm.com
EMAIL_FROM_NAME=AutoLLM

# ── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute

# ── Password Reset ───────────────────────────────────────────────────────
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
